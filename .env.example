# Copy to `.env` (dev) or `.env.prod` (release) and fill in.
# Loaded by scripts/bundle.sh and injected into Info.plist at build time.
# All of this is OPTIONAL: with nothing set, the editor still runs — only the
# AI/generation/account features are hidden (AccountService reports misconfigured).
# `swift run` does NOT read this file; use scripts/bundle.sh for a configured build.

# --- Backend: AI generation, in-app agent, accounts (your own Convex + Clerk) ---
CLERK_PUBLISHABLE_KEY=        # -> Info.plist PalmierClerkPublishableKey
CONVEX_DEPLOYMENT_URL=        # -> Info.plist PalmierConvexDeploymentURL (Convex sync URL)
CONVEX_HTTP_URL=              # -> Info.plist PalmierConvexHttpURL (Convex HTTP actions; agent streaming + sample projects)

# --- Telemetry (optional; no-op if unset) ---
SENTRY_DSN=

# --- Release signing / notarization (only for `bundle.sh release --sign|--dist`) ---
# Defaults in bundle.sh point at Palmier's identity; override with your own to distribute.
SIGNING_IDENTITY=            # e.g. "Developer ID Application: Your Name (TEAMID)"
PROVISION_PROFILE=          # path to your .provisionprofile
KEYCHAIN_ACCESS_GROUP=      # e.g. TEAMID.your.bundle.id
NOTARY_PROFILE=             # `xcrun notarytool store-credentials` profile name

# --- dSYM upload to Sentry on release (optional) ---
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
